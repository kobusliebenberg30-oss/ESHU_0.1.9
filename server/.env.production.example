# --- Runtime ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Database (Supabase) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# --- Sessions ---
SESSION_SECRET=replace-with-long-random-hex
SESSION_COOKIE_NAME=eshu.sid
SESSION_MAX_AGE_MS=2592000000

# --- Supabase Auth (browser sign-up / sign-in) ---
SUPABASE_URL=https://qyylmniugajchuynvjgv.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key

# --- CORS ---
CORS_ORIGIN=https://eshu-0-1-4.vercel.app

# --- Storage (Vercel) ---
STORAGE_DRIVER=supabase
STORAGE_SUPABASE_BUCKET=eshu-assets
STORAGE_MAX_BYTES=26214400
