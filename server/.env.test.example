# Copy to .env.test and fill in.
# Run `npm run db:test:setup` once after editing.

NODE_ENV=test
PORT=0
LOG_LEVEL=warn

# A SEPARATE database from your dev one. The test setup truncates aggressively.
DATABASE_URL=postgresql://eshu:eshu_dev@localhost:5432/eshu_test?schema=public
DIRECT_URL=postgresql://eshu:eshu_dev@localhost:5432/eshu_test?schema=public

SESSION_SECRET=test-secret-change-me-to-32-or-more-chars-please
SESSION_COOKIE_NAME=eshu.sid
SESSION_MAX_AGE_MS=2592000000

CORS_ORIGIN=http://localhost:3000,http://localhost:8080

STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage/test-assets
STORAGE_MAX_BYTES=26214400
