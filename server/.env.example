# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (local Docker) ---
# For Supabase production, see docs/DEPLOYMENT.md
DATABASE_URL=postgresql://eshu:eshu_dev@localhost:5432/eshu?schema=public
DIRECT_URL=postgresql://eshu:eshu_dev@localhost:5432/eshu?schema=public

# --- Sessions ---
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-long-random-hex
SESSION_COOKIE_NAME=eshu.sid
SESSION_MAX_AGE_MS=2592000000
# 'lax' for same-origin Vercel deploy (default). Use 'none' for split-origin local dev.
SESSION_COOKIE_SAME_SITE=lax

# --- Supabase (optional, but both values must be set together) ---
SUPABASE_URL=https://qyylmniugajchuynvjgv.supabase.co
# Legacy JWT anon key or new publishable key (Settings → API Keys)
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-or-publishable-key

# --- CORS (frontend origin(s), comma-separated) ---
# Production: include your Vercel URL(s). Preview URLs are auto-allowed on Vercel.
# Vercel production: set to your canonical deployment URL.
# Preview URLs (VERCEL_URL / VERCEL_BRANCH_URL) are auto-allowed by app.ts.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,https://your-app.vercel.app

# --- Storage ---
# Vercel: use STORAGE_LOCAL_DIR=/tmp/eshu-assets (ephemeral) until S3/Supabase Storage is wired.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage/assets
STORAGE_MAX_BYTES=26214400
