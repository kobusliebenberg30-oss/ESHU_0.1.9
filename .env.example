# ─────────────────────────────────────────────────────────────────────────────
# ESHU — root-level environment variable reference
# Copy this file to .env and fill in real values. Never commit .env.
#
# Vercel: add every variable below in
#   Project → Settings → Environment Variables
#   (set scope to Production + Preview + Development as appropriate)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Pooled connection — used by the Express server at runtime.
# Supabase dashboard → Project Settings → Database → Connection pooling
# Use port 6543, mode Transaction, append ?pgbouncer=true
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct (non-pooled) connection — used by Prisma migrate deploy only.
# Supabase dashboard → Project Settings → Database → Direct connection (port 5432)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Both must be set together or both left empty.
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-public-key>
# Server-only key used for private Supabase Storage buckets. Never expose this
# in frontend code or NEXT_PUBLIC/VITE-style variables.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_at_least_32_random_characters

SESSION_COOKIE_NAME=eshu.sid
# 30 days in milliseconds (default)
SESSION_MAX_AGE_MS=2592000000
# 'lax' for same-origin Vercel deploy (default).
# Set to 'none' only for split-origin local dev (pages :8080 + API :3000).
# 'none' forces secure:true so HTTPS (or localhost) is required.
SESSION_COOKIE_SAME_SITE=lax

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# For Vercel production set this to your canonical URL, e.g.:
#   CORS_ORIGIN=https://your-app.vercel.app
# For local split-origin dev:
#   CORS_ORIGIN=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Asset storage ─────────────────────────────────────────────────────────────
# 'local' stores files on disk for dev. Use 'supabase' for durable Vercel uploads.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage/assets
STORAGE_SUPABASE_BUCKET=eshu-assets
# Max upload size in bytes (default 25 MB)
STORAGE_MAX_BYTES=26214400
